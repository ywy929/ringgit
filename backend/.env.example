# Copy this file to .env and fill in values from Google Cloud Console.
# See README.md "Google Cloud setup" for the one-time setup walkthrough.
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8000/api/oauth/callback
FRONTEND_URL=http://localhost:5173

# Per-sender PDF passwords. Email-fetch will use these to decrypt the PDF
# attachment from each sender. Leave commented out (or empty) to fall through
# to the encrypted-stub path so you can upload manually instead.
# PDF_PASSWORD_TNG=your-mobile-number-without-country-code   # e.g. 1123456789
# PDF_PASSWORD_AEON=your-aeon-pdf-password                   # usually NRIC digits
# PDF_PASSWORD_MAYBANK=your-maybank-pdf-password             # see m2u@stmts.maybank2u.com.my email
